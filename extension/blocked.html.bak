<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>GISA — Site Blocked</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;background:#0a0a0a;color:#fff;min-height:100vh;display:flex;align-items:center;justify-content:center}
.container{max-width:600px;padding:48px 32px;text-align:center}
.shield{font-size:80px;margin-bottom:24px;display:block}
.title{font-size:32px;font-weight:700;color:#e24b4a;margin-bottom:8px}
.domain{font-size:18px;color:#888;font-family:monospace;margin-bottom:32px;word-break:break-all}
.badge{display:inline-block;padding:6px 16px;border-radius:20px;font-size:13px;font-weight:700;text-transform:uppercase;margin-bottom:32px;background:#333;color:#fff}
.hotline{background:#3a0000;border:1px solid #7c0000;border-radius:12px;padding:16px 20px;margin-bottom:24px;font-size:14px;color:#ffaaaa;text-align:left;display:none}
.score-bar{background:#1a1a1a;border-radius:12px;padding:16px 24px;margin-bottom:32px}
.score-label{display:flex;justify-content:space-between;font-size:13px;color:#666;margin-bottom:8px}
.bar{height:8px;background:#333;border-radius:4px;overflow:hidden}
.bar-fill{height:100%;border-radius:4px;background:linear-gradient(90deg,#e24b4a,#ff0000);width:0%;transition:width 0.5s ease}
.actions{display:flex;gap:12px;justify-content:center;flex-wrap:wrap;margin-bottom:32px}
.btn{padding:12px 24px;border-radius:8px;font-size:15px;font-weight:600;cursor:pointer;border:none}
.btn-back{background:#1d9e75;color:#fff}
.btn-report{background:#222;color:#e24b4a;border:1px solid #e24b4a}
.btn-proceed{background:#222;color:#666;border:1px solid #333}
.credit{font-size:12px;color:#333}
</style>
</head>
<body>
<div class="container">
  <span class="shield">🛡</span>
  <h1 class="title">Site Blocked</h1>
  <p class="domain" id="domain-display">unknown domain</p>
  <div class="badge" id="badge">THREAT DETECTED</div>
  <div class="hotline" id="hotline">
    <strong style="display:block;margin-bottom:6px;color:#ff6666">⚠️ This site may be linked to human trafficking.</strong>
    National Human Trafficking Hotline: <strong>1-888-373-7888</strong> (free, 24/7, confidential)
  </div>
  <div class="score-bar">
    <div class="score-label"><span>Threat Level</span><span id="score-display">--</span></div>
    <div class="bar"><div class="bar-fill" id="bar-fill"></div></div>
  </div>
  <div class="actions">
    <button class="btn btn-back" id="btn-back">← Go Back to Safety</button>
    <button class="btn btn-report" id="btn-report">🚩 Report This Site</button>
    <button class="btn btn-proceed" id="btn-proceed">Proceed Anyway (not recommended)</button>
  </div>
  <div class="credit">Protected by <span style="color:#555">GISA Safety Shield</span></div>
</div>
<script src="blocked.js"></script>
</body>
</html>
